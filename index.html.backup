.gallery{padding:80px 20px;background:var(--l)}.gg{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.gi{border-radius:10px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 3px 12px rgba(0,0,0,.08)}.gi img{width:100%;height:100%;object-fit:cover;transition:transform .5s}.gi:hover img{transform:scale(1.05)}
